generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id
  createdAt DateTime   @default(now())
  questions Question[]
  answers   Answer[]
}

model Question {
  id         String    @id @default(cuid())
  text       String
  type       String    // "yesno" | "multiplechoice"
  options    String?   // JSON: string[] for MC options
  authorId   String?   // device User who created it (mobile/web app); null for surveyor questions
  author     User?     @relation(fields: [authorId], references: [id])
  surveyorId String?   // Surveyor who created it (web surveyor dashboard); null for app questions
  surveyor   Surveyor? @relation(fields: [surveyorId], references: [id])
  createdAt  DateTime  @default(now())
  status     String    @default("active") // "active" | "closed"
  answers    Answer[]
}

model Surveyor {
  id           String     @id @default(cuid())
  handle       String     @unique
  passwordHash String // scrypt: "salt:hash"
  createdAt    DateTime   @default(now())
  questions    Question[]
}

model Answer {
  id         String   @id @default(cuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id])
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  value      String
  createdAt  DateTime @default(now())

  @@unique([questionId, userId])
}
